@{
    ViewBag.Title = "Customer Ledger Details";
    var customer = ViewBag.Customer as
        PharmacyProMS.Models.Customer;
    var invoices = ViewBag.Invoices as
        List<PharmacyProMS.Models.SaleInvoice>;
    var payments = ViewBag.Payments as
        List<PharmacyProMS.Models.CustomerPayment>;
    decimal totalDue = ViewBag.TotalDue ?? 0;
    decimal totalPaid = ViewBag.TotalPaid ?? 0;
    decimal totalSale = ViewBag.TotalSale ?? 0;
}

<div class="page-header">
    <div>
        <h4>
            <i class="fas fa-user me-2"
               style="color:#1a8a5a"></i>
            @(customer?.CustomerName) — Ledger
        </h4>
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item">
                <a href="@Url.Action("Index","Dashboard")">
                    Home
                </a>
            </li>
            <li class="breadcrumb-item">
                <a href="@Url.Action("Index")">
                    Customer Ledger
                </a>
            </li>
            <li class="breadcrumb-item active">
                Details
            </li>
        </ol>
    </div>
    <div class="d-flex gap-2">
        @if (totalDue > 0)
        {
            <a href="@Url.Action("CollectPayment",
                new{customerId=customer?.CustomerId})"
               class="btn btn-success">
                <i class="fas fa-money-bill-wave me-1"></i>
                Collect Payment
            </a>
        }
        <a href="@Url.Action("Index")"
           class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left me-1"></i> Back
        </a>
    </div>
</div>

@* Customer Info + Summary *@
<div class="row g-3 mb-4">

    @* Customer Info *@
    <div class="col-md-4">
        <div class="card p-4 text-center">
            <div style="width:70px;height:70px;
                        background:#e8f5ee;
                        border-radius:50%;
                        display:flex;
                        align-items:center;
                        justify-content:center;
                        margin:0 auto 12px">
                <i class="fas fa-user fa-2x"
                   style="color:#1a8a5a"></i>
            </div>
            <h5 class="fw-bold">
                @customer?.CustomerName
            </h5>
            <p class="text-muted mb-1">
                @customer?.Phone
            </p>
            <p class="text-muted small mb-3">
                @customer?.Address
            </p>

            @* Balance Summary *@
            <div class="p-3 rounded"
                 style="background:#f8f9fa">
                <div class="d-flex
                            justify-content-between mb-2">
                    <span class="text-muted small">
                        Total Credit:
                    </span>
                    <span class="fw-semibold">
                        ৳ @String.Format("{0:N2}", totalSale)
                    </span>
                </div>
                <div class="d-flex
                            justify-content-between mb-2">
                    <span class="text-muted small">
                        Total Paid:
                    </span>
                    <span class="fw-semibold text-success">
                        ৳ @String.Format("{0:N2}", totalPaid)
                    </span>
                </div>
                <hr class="my-2" />
                <div class="d-flex
                            justify-content-between">
                    <span class="fw-bold">Due:</span>
                    <span class="fw-bold @(totalDue > 0
                        ? "text-danger" : "text-success")"
                          style="font-size:18px">
                        ৳ @String.Format("{0:N2}", totalDue)
                    </span>
                </div>
            </div>
        </div>
    </div>

    @* Right — Invoices + Payments *@
    <div class="col-md-8">

        @* Credit Invoices *@
        <div class="card mb-3">
            <div class="card-header">
                <i class="fas fa-file-invoice me-2"></i>
                Credit Invoices
                <span class="badge ms-2"
                      style="background:#e8f5ee;
                             color:#1a8a5a">
                    @(invoices?.Count ?? 0)
                </span>
            </div>
            <div class="card-body p-0">
                <table class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th>Invoice</th>
                            <th>Date</th>
                            <th>Total</th>
                            <th>Paid</th>
                            <th>Due</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var inv in invoices ??
                            new List<PharmacyProMS
                                .Models.SaleInvoice>())
                        {
                            <tr>
                                <td class="fw-semibold"
                                    style="color:#1a8a5a">
                                    @inv.InvoiceNumber
                                </td>
                                <td>
                                    @inv.SaleDate.ToString(
                                        "dd MMM yyyy",
                                        System.Globalization
                                        .CultureInfo
                                        .InvariantCulture)
                                </td>
                                <td>
                                    ৳ @String.Format("{0:N2}",
                                    inv.NetAmount)
                                </td>
                                <td class="text-success">
                                    ৳ @String.Format("{0:N2}",
                                    inv.PaidAmount)
                                </td>
                                <td class="@(inv.DueAmount > 0
                                    ? "text-danger fw-bold" : "")">
                                    ৳ @String.Format("{0:N2}",
                                    inv.DueAmount)
                                </td>
                                <td>
                                    @if (inv.DueAmount > 0)
                                    {
                                        <span class="badge
                                                     bg-warning">
                                            Partial
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge
                                                     bg-success">
                                            Paid ✅
                                        </span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        @* Payment History *@
        <div class="card">
            <div class="card-header">
                <i class="fas fa-money-bill-wave me-2"></i>
                Payment History
                <span class="badge ms-2"
                      style="background:#e8f5ee;
                             color:#1a8a5a">
                    @(payments?.Count ?? 0)
                </span>
            </div>
            <div class="card-body p-0">
                <table class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Amount</th>
                            <th>Method</th>
                            <th>Note</th>
                            <th>By</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!payments?.Any() ?? true)
                        {
                            <tr>
                                <td colspan="5"
                                    class="text-center
                                           text-muted py-3">
                                    No payments yet
                                </td>
                            </tr>
                        }
                        @foreach (var p in payments ??
                            new List<PharmacyProMS
                                .Models.CustomerPayment>())
                        {
                            <tr>
                                <td>
                                    @p.PaymentDate.ToString(
                                        "dd MMM yyyy",
                                        System.Globalization
                                        .CultureInfo
                                        .InvariantCulture)
                                </td>
                                <td class="fw-bold
                                           text-success">
                                    ৳ @String.Format("{0:N2}",
                                    p.Amount)
                                </td>
                                <td>
                                    <span class="badge
                                                 bg-secondary">
                                        @p.PaymentMethod
                                    </span>
                                </td>
                                <td class="text-muted small">
                                    @(p.Note ?? "—")
                                </td>
                                <td class="text-muted small">
                                    @p.CreatedBy
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>