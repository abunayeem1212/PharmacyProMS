@model PharmacyProMS.ViewModels.ChangePasswordViewModel
@{
    ViewBag.Title = "Change Password";
}

<div class="page-header">
    <div>
        <h4>
            <i class="fas fa-key me-2"
               style="color:#1a8a5a"></i>
            Change Password
        </h4>
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item">
                <a href="@Url.Action("Index","Dashboard")">
                    Home
                </a>
            </li>
            <li class="breadcrumb-item">
                <a href="@Url.Action("Index")">Profile</a>
            </li>
            <li class="breadcrumb-item active">
                Change Password
            </li>
        </ol>
    </div>
</div>

<div class="row justify-content-center">
    <div class="col-md-5">
        <div class="card">
            <div class="card-header">
                <i class="fas fa-lock me-2"></i>
                Update Your Password
            </div>
            <div class="card-body p-4">

                @using (Html.BeginForm("ChangePassword",
                    "Profile", FormMethod.Post))
                {
                    @Html.AntiForgeryToken()
                    @Html.ValidationSummary(false, "",
                        new { @class = "alert alert-danger" })

                    <div class="mb-3">
                        <label class="form-label fw-semibold">
                            Current Password
                            <span class="text-danger">*</span>
                        </label>
                        @Html.PasswordFor(
                            m => m.CurrentPassword,
                            new
                                 {
                                     @class = "form-control",
                                  placeholder =
                                    "Enter current password",
                                  id = "currentPwd"
                                 })
                        @Html.ValidationMessageFor(
                            m => m.CurrentPassword, "",
                            new { @class = "text-danger small" })
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">
                            New Password
                            <span class="text-danger">*</span>
                        </label>
                        @Html.PasswordFor(
                            m => m.NewPassword,
                            new
                                 {
                                     @class = "form-control",
                                  placeholder =
                                    "Minimum 6 characters",
                                  id = "newPwd"
                                 })
                        @Html.ValidationMessageFor(
                            m => m.NewPassword, "",
                            new { @class = "text-danger small" })

                        @* Password Strength Bar *@
                        <div class="mt-2">
                            <div style="height:6px;
                                        background:#eee;
                                        border-radius:3px">
                                <div id="strengthBar"
                                     style="height:100%;
                                            width:0%;
                                            border-radius:3px;
                                            transition:all 0.3s">
                                </div>
                            </div>
                            <small id="strengthText"
                                   class="text-muted"></small>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-semibold">
                            Confirm New Password
                            <span class="text-danger">*</span>
                        </label>
                        @Html.PasswordFor(
                            m => m.ConfirmPassword,
                            new
                                 {
                                     @class = "form-control",
                                  placeholder =
                                    "Repeat new password"
                                 })
                        @Html.ValidationMessageFor(
                            m => m.ConfirmPassword, "",
                            new { @class = "text-danger small" })
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit"
                                class="btn btn-primary px-4">
                            <i class="fas fa-save me-2"></i>
                            Update Password
                        </button>
                        <a href="@Url.Action("Index")"
                           class="btn btn-outline-secondary px-4">
                            Cancel
                        </a>
                    </div>
                }
            </div>
        </div>

        @* Tips Card *@
        <div class="card mt-3">
            <div class="card-body">
                <h6 class="fw-bold mb-2">
                    <i class="fas fa-shield-alt me-2
                               text-success"></i>
                    Password Tips:
                </h6>
                <ul class="mb-0 small text-muted">
                    <li>Minimum 6 characters</li>
                    <li>Use uppercase & lowercase letters</li>
                    <li>Include numbers</li>
                    <li>Use special characters (!#$%)</li>
                </ul>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
    document.getElementById('newPwd')
        .addEventListener('input', function () {
        var pwd      = this.value;
        var strength = 0;
        var bar      = document.getElementById('strengthBar');
        var text     = document.getElementById('strengthText');

        if (pwd.length >= 6)   strength++;
        if (pwd.length >= 10)  strength++;
        if (/[A-Z]/.test(pwd)) strength++;
        if (/[0-9]/.test(pwd)) strength++;
        if (/[^A-Za-z0-9]/.test(pwd)) strength++;

        var colors  = ['#dc3545','#fd7e14',
                       '#ffc107','#20c997','#1a8a5a'];
        var labels  = ['Very Weak','Weak',
                       'Fair','Good','Strong'];
        var widths  = ['20%','40%','60%','80%','100%'];

        if (pwd.length === 0) {
            bar.style.width = '0%';
            text.textContent = '';
        } else {
            var idx = Math.min(strength - 1, 4);
            idx = Math.max(idx, 0);
            bar.style.width            = widths[idx];
            bar.style.background       = colors[idx];
            text.textContent           = labels[idx];
            text.style.color           = colors[idx];
        }
    });
    </script>
}