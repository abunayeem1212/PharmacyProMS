@model PharmacyProMS.Models.Company
@{
    ViewBag.Title = "Company Details";
}

<div class="page-header">
    <div>
        <h4>
            <i class="fas fa-info-circle me-2" style="color:#1a8a5a"></i>
            Company Details
        </h4>
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item">
                <a href="@Url.Action("Index","Dashboard")">Home</a>
            </li>
            <li class="breadcrumb-item">
                <a href="@Url.Action("Index")">Companies</a>
            </li>
            <li class="breadcrumb-item active">Details</li>
        </ol>
    </div>
    <div class="d-flex gap-2">
        <a href="@Url.Action("Edit", new { id = Model.CompanyId })"
           class="btn btn-warning">
            <i class="fas fa-edit me-1"></i> Edit
        </a>
        <a href="@Url.Action("Index")"
           class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left me-1"></i> Back
        </a>
    </div>
</div>

<div class="row g-3">
    @* Company Info Card *@
    <div class="col-md-4">
        <div class="card text-center p-4">
            @if (!string.IsNullOrEmpty(Model.LogoPath))
            {
                <img src="@Model.LogoPath"
                     style="width:100px;height:100px;
                            border-radius:50%;
                            object-fit:cover;
                            border:3px solid #1a8a5a;
                            margin:0 auto 15px" />
            }
            else
            {
                <div style="width:100px;height:100px;
                            background:#e8f5ee;border-radius:50%;
                            display:flex;align-items:center;
                            justify-content:center;margin:0 auto 15px">
                    <i class="fas fa-building fa-3x"
                       style="color:#1a8a5a"></i>
                </div>
            }
            <h5 class="fw-bold">@Model.CompanyName</h5>
            <span class="badge @(Model.IsActive
                ? "bg-success" : "bg-secondary")">
                @(Model.IsActive ? "Active" : "Inactive")
            </span>
            <hr />
            <div class="text-start">
                <p class="mb-1">
                    <i class="fas fa-phone me-2 text-muted"></i>
                    @(Model.Phone ?? "—")
                </p>
                <p class="mb-1">
                    <i class="fas fa-envelope me-2 text-muted"></i>
                    @(Model.Email ?? "—")
                </p>
                <p class="mb-0">
                    <i class="fas fa-map-marker-alt me-2 text-muted"></i>
                    @(Model.Address ?? "—")
                </p>
            </div>
        </div>
    </div>

    @* Medicines List *@
    <div class="col-md-8">
        <div class="card">
            <div class="card-header">
                <i class="fas fa-pills me-2"></i>
                Medicines Under This Company
                <span class="badge ms-2"
                      style="background:#e8f5ee;color:#1a8a5a">
                    @(Model.Medicines?.Count ?? 0)
                </span>
            </div>
            <div class="card-body p-0">
                <table class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Medicine Name</th>
                            <th>Generic</th>
                            <th>Price</th>
                            <th>Stock</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Medicines == null || !Model.Medicines.Any())
                        {
                            <tr>
                                <td colspan="6"
                                    class="text-center text-muted py-4">
                                    No medicines found
                                </td>
                            </tr>
                        }
                        @{int i = 1;}
                        @foreach (var med in Model.Medicines ??
                            new List<PharmacyProMS.Models.Medicine>())
                        {
                            <tr>
                                <td>@i</td>
                                <td class="fw-semibold">
                                    @med.MedicineName
                                </td>
                                <td class="text-muted">
                                    @med.GenericName
                                </td>
                                <td>৳ @med.SalePrice</td>
                                <td>
                                    <span class="badge @(med.CurrentStock
                                        <= med.ReOrderLevel
                                        ? "bg-danger" : "bg-success")">
                                        @med.CurrentStock
                                    </span>
                                </td>
                                <td>
                                    <span class="badge @(med.IsActive
                                        ? "bg-success" : "bg-secondary")">
                                        @(med.IsActive
                                            ? "Active" : "Inactive")
                                    </span>
                                </td>
                            </tr>
                            i++;
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
