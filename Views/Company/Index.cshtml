@model PharmacyProMS.ViewModels.CompanyListViewModel
@{
    ViewBag.Title = "Companies";
}

<div class="page-header">
    <div>
        <h4>
            <i class="fas fa-building me-2" style="color:#1a8a5a"></i>
            Company Management
        </h4>
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item">
                <a href="@Url.Action("Index","Dashboard")">Home</a>
            </li>
            <li class="breadcrumb-item active">Companies</li>
        </ol>
    </div>
    <a href="@Url.Action("Create")" class="btn btn-primary">
        <i class="fas fa-plus me-1"></i> Add Company
    </a>
</div>

@* Stats Cards *@
<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card text-center py-3">
            <div style="font-size:28px;font-weight:700;color:#1a8a5a">
                @Model.TotalCount
            </div>
            <div class="text-muted small">Total Companies</div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card text-center py-3">
            <div style="font-size:28px;font-weight:700;color:#28a745">
                @Model.Companies.Count(c => c.IsActive)
            </div>
            <div class="text-muted small">Active</div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card text-center py-3">
            <div style="font-size:28px;font-weight:700;color:#dc3545">
                @Model.Companies.Count(c => !c.IsActive)
            </div>
            <div class="text-muted small">Inactive</div>
        </div>
    </div>
</div>

@* DataTable Card *@
<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span>
            <i class="fas fa-list me-2"></i>
            Company List
        </span>
    </div>
    <div class="card-body">
        <table id="companyTable" class="table table-hover w-100">
            <thead>
                <tr>
                    <th style="width: 50px">#</th>
                    <th style="width: 70px">Logo</th>
                    <th>Company Name</th>
                    <th>Phone</th>
                    <th>Email</th>
                    <th style="width: 100px">Medicines</th>
                    <th style="width: 100px">Status</th>
                    <th style="width: 120px">Actions</th>
                </tr>
            </thead>
            <tbody>
                @{ int sl = 1; }
                @foreach (var item in Model.Companies)
                {
                    <tr id="row-@item.CompanyId">
                        <td class="text-muted">@sl</td>
                        <td>
                            @if (!string.IsNullOrEmpty(item.LogoPath))
                            {
                                <img src="@item.LogoPath"
                                     style="width:38px; height:38px; border-radius:8px; object-fit:cover"
                                     alt="Logo" />
                            }
                            else
                            {
                                <div style="width:38px; height:38px; background:#e8f5ee; border-radius:8px;
                                            display:flex; align-items:center; justify-content:center">
                                    <i class="fas fa-building" style="color:#1a8a5a"></i>
                                </div>
                            }
                        </td>
                        <td>
                            <div class="fw-semibold">@item.CompanyName</div>
                            <small class="text-muted">@item.Address</small>
                        </td>
                        <td>@item.Phone</td>
                        <td>@item.Email</td>
                        <td>
                            <span class="badge" style="background:#e8f5ee; color:#1a8a5a">
                                @(item.Medicines != null ? item.Medicines.Count : 0)
                            </span>
                        </td>
                        <td>
                            <span class="badge @(item.IsActive ? "bg-success" : "bg-secondary")"
                                  style="cursor:pointer"
                                  onclick="toggleStatus(@item.CompanyId, this)"
                                  title="Click to toggle status">
                                @(item.IsActive ? "Active" : "Inactive")
                            </span>
                        </td>
                        <td>
                            <div class="d-flex gap-1">
                                <a href="@Url.Action("Details", new { id = item.CompanyId })"
                                   class="btn btn-sm btn-outline-info" title="Details">
                                    <i class="fas fa-eye"></i>
                                </a>
                                <a href="@Url.Action("Edit", new { id = item.CompanyId })"
                                   class="btn btn-sm btn-outline-warning" title="Edit">
                                    <i class="fas fa-edit"></i>
                                </a>
                                <button class="btn btn-sm btn-outline-danger"
                                    onclick="confirmDelete(@item.CompanyId,
                                        '@item.CompanyName', 'Company')"                                        title="Delete">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </div>
                        </td>
                    </tr>
                    sl++;
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            // Initialize DataTable
            var table = $('#companyTable').DataTable({
                responsive: true,
                pageLength: 10,
                lengthMenu: [[10, 25, 50, 100, -1], [10, 25, 50, 100, "All"]],
                order: [[2, 'asc']], // Sort by Company Name by default
                columnDefs: [
                    { orderable: false, targets: [0, 1, 5, 6, 7] }, // Disable sorting on #, Logo, Medicines, Status, Actions
                    { searchable: false, targets: [0, 1, 5, 7] } // Disable search on #, Logo, Medicines, Actions
                ],
                language: {
                    search: "🔍 Search:",
                    lengthMenu: "Show _MENU_ entries",
                    info: "Showing _START_ to _END_ of _TOTAL_ entries",
                    infoEmpty: "Showing 0 to 0 of 0 entries",
                    infoFiltered: "(filtered from _MAX_ total entries)",
                    emptyTable: "No companies found",
                    paginate: {
                        first: "First",
                        last: "Last",
                        previous: "‹",
                        next: "›"
                    }
                },
                drawCallback: function() {
                    // Re-initialize tooltips if any
                    $('[data-toggle="tooltip"]').tooltip();
                }
            });

            // Optional: Add custom search styling
            $('#companyTable_filter').addClass('mb-3');
            $('#companyTable_filter label').addClass('form-label');
            $('#companyTable_filter input').addClass('form-control form-control-sm');
            $('#companyTable_length select').addClass('form-select form-select-sm');
        });

        // Toggle Company Status
        function toggleStatus(id, badge) {
            if (!confirm('Are you sure you want to change the status?')) return;

            $.ajax({
                url: '@Url.Action("ToggleStatus", "Company")',
                type: 'POST',
                data: {
                    id: id,
                    __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                },
                success: function(res) {
                    if (res.success) {
                        // Update badge appearance and text
                        $(badge)
                            .removeClass('bg-success bg-secondary')
                            .addClass(res.isActive ? 'bg-success' : 'bg-secondary')
                            .text(res.isActive ? 'Active' : 'Inactive');

                        // Update stats cards (optional)
                        updateStats();

                        toastr.success(res.message);
                    } else {
                        toastr.error(res.message);
                    }
                },
                error: function() {
                    toastr.error('An error occurred while toggling status');
                }
            });
        }

        // Delete Company
        @*function deleteCompany(id, name) {
            if (!confirm('Are you sure you want to delete "' + name + '"? This action cannot be undone.')) return;

            $.ajax({
                url: '@Url.Action("Delete", "Company")',
                type: 'POST',
                data: {
                    id: id,
                    __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                },
                success: function(res) {
                    if (res.success) {
                        var table = $('#companyTable').DataTable();
                        var row = $('#row-' + id);

                        // Remove row with fade effect
                        row.fadeOut(400, function() {
                            table.row(row).remove().draw();
                        });

                        // Update stats
                        updateStats();

                        toastr.success(res.message);
                    } else {
                        toastr.error(res.message);
                    }
                },
                error: function() {
                    toastr.error('An error occurred while deleting the company');
                }
            });
        }*@

        // Update statistics cards after changes
        function updateStats() {
            $.ajax({
                url: '@Url.Action("GetStats", "Company")',
                type: 'GET',
                success: function(res) {
                    if (res.success) {
                        // Update stats cards
                        $('.col-md-4:eq(0) div:first').text(res.totalCount);
                        $('.col-md-4:eq(1) div:first').text(res.activeCount);
                        $('.col-md-4:eq(2) div:first').text(res.inactiveCount);
                    }
                }
            });
        }
    </script>

    @Html.AntiForgeryToken()
}