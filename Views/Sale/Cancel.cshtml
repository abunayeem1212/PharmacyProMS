@model PharmacyProMS.Models.SaleInvoice
@{
    ViewBag.Title = "Cancel Invoice";
}

<div class="page-header">
    <div>
        <h4>
            <i class="fas fa-ban me-2 text-danger"></i>
            Cancel Invoice
        </h4>
    </div>
    <a href="@Url.Action("Details",
        new{id=Model.InvoiceId})"
       class="btn btn-outline-secondary">
        <i class="fas fa-arrow-left me-1"></i> Back
    </a>
</div>

<div class="row justify-content-center">
    <div class="col-md-6">

        @* Invoice Info *@
        <div class="card mb-3"
             style="border-left:4px solid #dc3545">
            <div class="card-body">
                <div class="row text-center">
                    <div class="col-4">
                        <div class="text-muted small">
                            Invoice No
                        </div>
                        <div class="fw-bold text-danger">
                            @Model.InvoiceNumber
                        </div>
                    </div>
                    <div class="col-4">
                        <div class="text-muted small">
                            Net Amount
                        </div>
                        <div class="fw-bold">
                            ৳ @String.Format("{0:N2}",
                              Model.NetAmount)
                        </div>
                    </div>
                    <div class="col-4">
                        <div class="text-muted small">
                            Date
                        </div>
                        <div class="fw-bold">
                            @Model.SaleDate.ToString(
                                "dd MMM yyyy",
                                System.Globalization
                                .CultureInfo.InvariantCulture)
                        </div>
                    </div>
                </div>
            </div>
        </div>

        @* Warning *@
        <div class="alert alert-danger mb-3">
            <i class="fas fa-exclamation-triangle me-2"></i>
            <strong>Warning!</strong>
            This action cannot be undone.
            <ul class="mt-2 mb-0 small">
                <li>Stock will be restored</li>
                <li>Invoice will be marked as Cancelled</li>
                <li>Customer due will be cleared</li>
            </ul>
        </div>

        @* Cancel Form *@
        <div class="card">
            <div class="card-header fw-bold text-danger">
                <i class="fas fa-ban me-2"></i>
                Cancel Invoice
            </div>
            <div class="card-body p-4">
                @using (Html.BeginForm("Cancel", "Sale",
                    new { id = Model.InvoiceId },
                    FormMethod.Post))
                {
                    @Html.AntiForgeryToken()

                    <div class="mb-4">
                        <label class="form-label fw-semibold">
                            Cancellation Reason
                            <span class="text-danger">*</span>
                        </label>
                        <textarea name="cancelReason"
                                  class="form-control"
                                  rows="3"
                                  required
                                  placeholder="Enter reason for cancellation...">
                        </textarea>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit"
                                class="btn btn-danger px-4"
                                onclick="return confirm(
                                    'Are you sure? This cannot be undone!')">
                            <i class="fas fa-ban me-2"></i>
                            Confirm Cancel
                        </button>
                        <a href="@Url.Action("Details",
                            new{id=Model.InvoiceId})"
                           class="btn btn-outline-secondary px-4">
                            Go Back
                        </a>
                    </div>
                }
            </div>
        </div>
    </div>
</div>