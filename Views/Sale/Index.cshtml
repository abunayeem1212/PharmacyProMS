@model PharmacyProMS.ViewModels.SaleListViewModel
@{
    ViewBag.Title = "Sale Invoices";
}

<div class="page-header">
    <div>
        <h4>
            <i class="fas fa-file-invoice me-2"
               style="color:#1a8a5a"></i>
            Sale Management
        </h4>
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item">
                <a href="@Url.Action("Index","Dashboard")">Home</a>
            </li>
            <li class="breadcrumb-item active">Sales</li>
        </ol>
    </div>
    <a href="@Url.Action("Create")" class="btn btn-primary">
        <i class="fas fa-plus me-1"></i> New Sale
    </a>
</div>

@* Summary *@
<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card p-3">
            <div class="d-flex align-items-center gap-3">
                <div style="width:50px;height:50px;
                            background:#e8f5ee;border-radius:12px;
                            display:flex;align-items:center;
                            justify-content:center">
                    <i class="fas fa-file-invoice"
                       style="color:#1a8a5a;font-size:20px"></i>
                </div>
                <div>
                    <div style="font-size:22px;font-weight:700">
                        @Model.TotalCount
                    </div>
                    <div class="text-muted small">
                        Total Invoices
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card p-3">
            <div class="d-flex align-items-center gap-3">
                <div style="width:50px;height:50px;
                            background:#e3f2fd;border-radius:12px;
                            display:flex;align-items:center;
                            justify-content:center">
                    <i class="fas fa-coins"
                       style="color:#2196f3;font-size:20px"></i>
                </div>
                <div>
                    <div style="font-size:20px;font-weight:700;
                                color:#2196f3">
                        ৳ @Model.TotalSaleAmount.ToString("N2")
                    </div>
                    <div class="text-muted small">Total Sales</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card p-3">
            <div class="d-flex align-items-center gap-3">
                <div style="width:50px;height:50px;
                            background:#fff3e0;border-radius:12px;
                            display:flex;align-items:center;
                            justify-content:center">
                    <i class="fas fa-percentage"
                       style="color:#ff9800;font-size:20px"></i>
                </div>
                <div>
                    <div style="font-size:20px;font-weight:700;
                                color:#ff9800">
                        ৳ @Model.TotalVatAmount.ToString("N2")
                    </div>
                    <div class="text-muted small">Total VAT</div>
                </div>
            </div>
        </div>
    </div>
</div>

@* Filter *@
<div class="card mb-3">
    <div class="card-body py-3">
        @using (Html.BeginForm("Index", "Sale",
            FormMethod.Get,
            new { @class = "row g-2 align-items-end" }))
        {
            <div class="col-md-3">
                <label class="form-label fw-semibold small">
                    Search
                </label>
                <div class="input-group">
                    <span class="input-group-text bg-white">
                        <i class="fas fa-search text-muted"></i>
                    </span>
                    <input type="text" name="searchTerm"
                           value="@Model.SearchTerm"
                           class="form-control"
                           placeholder="Invoice no, customer..." />
                </div>
            </div>
            <div class="col-md-2">
                <label class="form-label fw-semibold small">
                    Date From
                </label>
                <input type="date" name="dateFrom"
                       class="form-control"
                       value="@(Model.DateFrom.HasValue
                           ? Model.DateFrom.Value
                               .ToString("yyyy-MM-dd") : "")" />
            </div>
            <div class="col-md-2">
                <label class="form-label fw-semibold small">
                    Date To
                </label>
                <input type="date" name="dateTo"
                       class="form-control"
                       value="@(Model.DateTo.HasValue
                           ? Model.DateTo.Value
                               .ToString("yyyy-MM-dd") : "")" />
            </div>
            <div class="col-md-2">
                <label class="form-label fw-semibold small">
                    Sort By
                </label>
                <select name="sortBy" class="form-select">
                    <option value="SaleDate"
                            @(Model.SortBy == "SaleDate" ? "selected" : "")>
                        Date
                    </option>
                    <option value="NetAmount"
                            @(Model.SortBy == "NetAmount" ? "selected" : "")>
                        Amount
                    </option>
                </select>
            </div>
            <div class="col-md-3 d-flex gap-2">
                <button type="submit"
                        class="btn btn-primary w-100">
                    <i class="fas fa-filter me-1"></i> Filter
                </button>
                <a href="@Url.Action("Index")"
                   class="btn btn-outline-secondary">
                    <i class="fas fa-redo"></i>
                </a>
            </div>
        }
    </div>
</div>

@* Table *@
<div class="card">
    <div class="card-header d-flex justify-content-between">
        <span>
            <i class="fas fa-list me-2"></i>
            Invoice List
            <span class="badge ms-2"
                  style="background:#e8f5ee;color:#1a8a5a">
                @Model.TotalCount Records
            </span>
        </span>
        <small class="text-muted">
            Page @Model.CurrentPage of @Model.TotalPages
        </small>
    </div>

    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Invoice No</th>
                        <th>Date</th>
                        <th>Customer</th>
                        <th>Items</th>
                        <th>Total</th>
                        <th>VAT</th>
                        <th>Due</th>
                        <th>Status</th>
                        <th>Net Amount</th>
                        <th style="width:100px">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Invoices.Any())
                    {
                        <tr>
                            <td colspan="9"
                                class="text-center py-5">
                                <i class="fas fa-inbox"
                                   style="font-size:40px;
                                          color:#ddd"></i>
                                <p class="text-muted mt-2">
                                    No invoices found
                                </p>
                            </td>
                        </tr>
                    }
                    @{ int sl = (Model.CurrentPage - 1) * Model.PageSize + 1; }

                    @foreach (var item in Model.Invoices)
                    {
                        bool isCancelled = item.InvoiceStatus == "Cancelled";

                        <tr id="sale-row-@item.InvoiceId"
                            class="@(isCancelled ? "table-secondary" : "")">

                            <td class="text-muted">@sl</td>

                            <td>
                                <a href="@Url.Action("Details",
                new { id = item.InvoiceId })"
                                   class="fw-semibold text-decoration-none"
                                   style="color:#1a8a5a">
                                    @item.InvoiceNumber
                                </a>
                            </td>

                            <td>
                                @item.SaleDate.ToString("dd MMM yyyy",
                                    System.Globalization.CultureInfo.InvariantCulture)
                            </td>

                            <td>
                                @if (item.Customer != null)
                                {
                                    <span class="badge"
                                          style="background:#e8f5ee;color:#1a8a5a">
                                        @item.Customer.CustomerName
                                    </span>
                                }
                                else
                                {
                                    <span class="text-muted small">
                                        @(item.WalkInCustomerName ?? "Walk-in")
                                    </span>
                                }
                            </td>

                            <td>
                                <span class="badge bg-secondary">
                                    @(item.SaleItems?.Count ?? 0) items
                                </span>
                            </td>

                            <td>
                                ৳ @item.TotalAmount.ToString("N2")
                            </td>

                            <td class="text-warning">
                                ৳ @item.VatAmount.ToString("N2")
                            </td>

                            @* Due *@
                            <td>
                                @if (item.IsCreditSale)
                                {
                                    <span class="badge @(item.DueAmount > 0
                    ? "bg-danger" : "bg-success")">

                                        @if (item.DueAmount > 0)
                                        {
                                            <text>৳ @String.Format("{0:N2}",
                                        item.DueAmount)</text>
                                        }
                                        else
                                        {
                                            <text>Paid ✅</text>
                                        }
                                    </span>
                                }
                                else
                                {
                                    <span class="text-muted small">—</span>
                                }
                            </td>

                            @* Status *@
                            <td>
                                @if (isCancelled)
                                {
                                    <span class="badge bg-dark">
                                        <i class="fas fa-ban me-1"></i>
                                        Cancelled
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-success">
                                        Active
                                    </span>
                                }
                            </td>

                            <td class="fw-bold" style="color:#1a8a5a">
                                ৳ @item.NetAmount.ToString("N2")
                            </td>
                             
                            <td>
                                <div class="d-flex gap-1">

                                    <a href="@Url.Action("Details",
                    new { id = item.InvoiceId })"
                                       class="btn btn-sm btn-outline-info">
                                        <i class="fas fa-eye"></i>
                                    </a>

                                    @if (!isCancelled && User.IsInRole("Admin"))
                                    {
                                        <button class="btn btn-sm btn-outline-danger"
                                                onclick="deleteSale(
                                @item.InvoiceId,
                                '@item.InvoiceNumber')">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    }

                                </div>
                            </td>
                        </tr>

                        sl++;
                    }
                </tbody>
            </table>
        </div>
    </div>

    @* Pagination *@
    @if (Model.TotalPages > 1)
    {
        <div class="card-footer d-flex justify-content-between">
            <small class="text-muted">
                Showing @((Model.CurrentPage-1)*Model.PageSize+1)
                to @(Math.Min(
                    Model.CurrentPage*Model.PageSize,
                    Model.TotalCount))
                of @Model.TotalCount
            </small>
            <ul class="pagination pagination-sm mb-0">
                <li class="page-item
                    @(Model.CurrentPage==1?"disabled":"")">
                    <a class="page-link"
                       href="@Url.Action("Index", new {
                           searchTerm = Model.SearchTerm,
                           sortBy     = Model.SortBy,
                           sortOrder  = Model.SortOrder,
                           page       = Model.CurrentPage-1})">
                        <i class="fas fa-chevron-left"></i>
                    </a>
                </li>
                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item
                        @(i==Model.CurrentPage?"active":"")">
                        <a class="page-link"
                           href="@Url.Action("Index", new {
                               searchTerm = Model.SearchTerm,
                               sortBy     = Model.SortBy,
                               sortOrder  = Model.SortOrder,
                               page       = i })">@i</a>
                        </li>
                    }
                <li class="page-item
                    @(Model.CurrentPage==Model.TotalPages
                        ?"disabled":"")">
                    <a class="page-link"
                       href="@Url.Action("Index", new {
                           searchTerm = Model.SearchTerm,
                           sortBy     = Model.SortBy,
                           sortOrder  = Model.SortOrder,
                           page       = Model.CurrentPage+1})">
                        <i class="fas fa-chevron-right"></i>
                    </a>
                </li>
            </ul>
        </div>
    }
</div>

@section Scripts {
    <script>
    function deleteSale(id, num) {
        if (!confirm('Delete Invoice "' + num + '"?\n' +
            'Stock will be reversed!')) return;
        $.ajax({
            url: '@Url.Action("Delete","Sale")',
            type: 'POST',
            data: {
                id: id,
                __RequestVerificationToken:
                    $('input[name="__RequestVerificationToken"]')
                    .val()
            },
            success: function (res) {
                if (res.success) {
                    $('#sale-row-' + id).fadeOut(400,
                        function () { $(this).remove(); });
                    toastr.success(res.message);
                } else {
                    toastr.error(res.message);
                }
            }
        });
    }
    </script>
    @Html.AntiForgeryToken()
}