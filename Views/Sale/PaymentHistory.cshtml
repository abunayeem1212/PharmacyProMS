@model PharmacyProMS.Models.SaleInvoice
@{
    ViewBag.Title = "Payment History";
    var payments = ViewBag.Payments as
        List<PharmacyProMS.Models.CustomerPayment>
        ?? new List<PharmacyProMS.Models
            .CustomerPayment>();
    decimal totalPaid = ViewBag.TotalPaid ?? 0;
    decimal due = Model.NetAmount - Model.PaidAmount;
}

<div class="page-header">
    <div>
        <h4>
            <i class="fas fa-history me-2"
               style="color:#1a8a5a"></i>
            Payment History —
            @Model.InvoiceNumber
        </h4>
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item">
                <a href="@Url.Action("Index","Dashboard")">
                    Home
                </a>
            </li>
            <li class="breadcrumb-item">
                <a href="@Url.Action("Details",
                    new{id=Model.InvoiceId})">
                    @Model.InvoiceNumber
                </a>
            </li>
            <li class="breadcrumb-item active">
                Payment History
            </li>
        </ol>
    </div>
    <a href="@Url.Action("Details",
        new{id=Model.InvoiceId})"
       class="btn btn-outline-secondary">
        <i class="fas fa-arrow-left me-1"></i> Back
    </a>
</div>

<div class="row g-3">

    @* Left — Invoice Summary *@
    <div class="col-md-4">

        @* Invoice Card *@
        <div class="card mb-3"
             style="border-top:3px solid #1a8a5a">
            <div class="card-body text-center py-4">
                <div class="text-muted small mb-1">
                    @Model.InvoiceNumber
                </div>
                <div class="text-muted small mb-3">
                    @Model.SaleDate.ToString("dd MMM yyyy",
                        System.Globalization.CultureInfo
                        .InvariantCulture)
                </div>

                <div class="row g-2">
                    <div class="col-4">
                        <div style="background:#f8f9fa;
                                    border-radius:10px;
                                    padding:10px">
                            <div class="text-muted small">
                                Total
                            </div>
                            <div class="fw-bold"
                                 style="color:#2196f3">
                                ৳@String.Format("{0:N0}",
                                  Model.NetAmount)
                            </div>
                        </div>
                    </div>
                    <div class="col-4">
                        <div style="background:#f8f9fa;
                                    border-radius:10px;
                                    padding:10px">
                            <div class="text-muted small">
                                Paid
                            </div>
                            <div class="fw-bold text-success">
                                ৳@String.Format("{0:N0}",
                                  Model.PaidAmount)
                            </div>
                        </div>
                    </div>
                    <div class="col-4">
                        <div style="background:@(due > 0
                                ? "#fff3f3" : "#f0fff4");
                                    border-radius:10px;
                                    padding:10px">
                            <div class="text-muted small">
                                Due
                            </div>
                            <div class="fw-bold
                                @(due > 0
                                    ? "text-danger"
                                    : "text-success")">
                                ৳@String.Format("{0:N0}",
                                  due)
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        @* Add Payment Card *@
        @if (due > 0 &&
             Model.InvoiceStatus != "Cancelled")
        {
            <div class="card">
                <div class="card-header fw-semibold">
                    <i class="fas fa-plus-circle
                               me-2 text-success"></i>
                    Add Payment
                </div>
                <div class="card-body p-3">
                    <div class="mb-3">
                        <label class="form-label
                                      fw-semibold small">
                            Amount (৳)
                            <span class="text-danger">*</span>
                        </label>
                        <div class="input-group">
                            <span class="input-group-text
                                         bg-white">৳</span>
                            <input type="number"
                                   id="newPayAmt"
                                   class="form-control"
                                   min="0.01"
                                   step="0.01"
                                   max="@due"
                                   placeholder="0.00" />
                        </div>
                        <button type="button"
                                class="btn btn-sm
                                       btn-outline-success
                                       mt-1 w-100"
                                onclick="payFull()">
                            Pay Full
                            (৳@String.Format("{0:N2}", due))
                        </button>
                    </div>

                    <div class="mb-3">
                        <label class="form-label
                                      fw-semibold small">
                            Method
                        </label>
                        <select id="newPayMethod"
                                class="form-select
                                       form-select-sm">
                            <option value="Cash">
                                💵 Cash
                            </option>
                            <option value="bKash">
                                📱 bKash
                            </option>
                            <option value="Nagad">
                                📱 Nagad
                            </option>
                            <option value="Card">
                                💳 Card
                            </option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <input type="text"
                               id="newPayNote"
                               class="form-control
                                      form-control-sm"
                               placeholder="Note (optional)" />
                    </div>

                    <button type="button"
                            class="btn btn-success w-100"
                            onclick="addPayment()">
                        <i class="fas fa-check me-2"></i>
                        Add Payment
                    </button>
                </div>
            </div>
        }
        else if (due <= 0)
        {
            <div class="card">
                <div class="card-body text-center py-3">
                    <i class="fas fa-check-circle"
                       style="font-size:35px;
                              color:#1a8a5a"></i>
                    <p class="fw-bold mt-2 text-success">
                        Fully Paid ✅
                    </p>
                </div>
            </div>
        }
    </div>

    @* Right — Payment Timeline *@
    <div class="col-md-8">
        <div class="card">
            <div class="card-header fw-bold">
                <i class="fas fa-list me-2"></i>
                Payment History
                <span class="badge ms-2"
                      style="background:#e8f5ee;
                             color:#1a8a5a">
                    @payments.Count payments
                </span>
            </div>
            <div class="card-body p-0">

                @if (!payments.Any())
                {
                    <div class="text-center py-5 text-muted">
                        <i class="fas fa-inbox"
                           style="font-size:40px;
                                  margin-bottom:10px;
                                  display:block"></i>
                        No payment records yet
                    </div>
                }

                @* Timeline *@
                <div class="p-3">
                    @{ int i = 1; }
                    @foreach (var p in payments)
                    {
                        string pmIcon =
                            p.PaymentMethod == "bKash" ||
                            p.PaymentMethod == "Nagad"
                                ? "fa-mobile-alt"
                                : p.PaymentMethod == "Card"
                                    ? "fa-credit-card"
                                    : "fa-money-bill-wave";

                        <div class="d-flex gap-3 mb-3"
                             id="pay-@p.PaymentId">
                            @* Icon *@
                            <div style="flex-shrink:0">
                                <div style="width:42px;
                                            height:42px;
                                            background:#e8f5ee;
                                            border-radius:50%;
                                            display:flex;
                                            align-items:center;
                                            justify-content:center">
                                    <i class="fas @pmIcon"
                                       style="color:#1a8a5a"></i>
                                </div>
                                @if (i < payments.Count)
                                {
                                    <div style="width:2px;
                                                height:30px;
                                                background:#e8f5ee;
                                                margin:4px auto">
                                    </div>
                                }
                            </div>

                            @* Content *@
                            <div class="flex-grow-1
                                        p-3 rounded"
                                 style="background:#f8f9fa;
                                        border:1px solid #eee">
                                <div class="d-flex
                                            justify-content-between
                                            align-items-start">
                                    <div>
                                        <span class="fw-bold"
                                              style="color:#1a8a5a;
                                                     font-size:18px">
                                            ৳ @String.Format(
                                            "{0:N2}", p.Amount)
                                        </span>
                                        <span class="badge
                                                     bg-secondary
                                                     ms-2">
                                            @p.PaymentMethod
                                        </span>
                                    </div>
                                    <div class="text-muted
                                                small">
                                        #@i
                                    </div>
                                </div>
                                <div class="text-muted
                                            small mt-1">
                                    <i class="fas fa-calendar
                                               me-1"></i>
                                    @p.PaymentDate.ToString(
                                        "dd MMM yyyy",
                                        System.Globalization
                                        .CultureInfo
                                        .InvariantCulture)
                                    &nbsp;|&nbsp;
                                    <i class="fas fa-user
                                               me-1"></i>
                                    @p.CreatedBy
                                    @if (!string
                                        .IsNullOrEmpty(p.Note))
                                    {
                                        <span>
                                            &nbsp;|&nbsp;
                                            @p.Note
                                        </span>
                                    }
                                </div>
                            </div>
                        </div>
                        i++;
                    }
                </div>

                @* Total *@
                @if (payments.Any())
                {
                    <div class="px-3 pb-3">
                        <div class="d-flex
                                    justify-content-between
                                    p-3 rounded fw-bold"
                             style="background:#e8f5ee;
                                    color:#1a8a5a">
                            <span>Total Paid:</span>
                            <span>
                                ৳ @String.Format("{0:N2}",
                                totalPaid)
                            </span>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
    var maxDue = @due;
    var invId  = @Model.InvoiceId;

    function payFull() {
        document.getElementById('newPayAmt').value
            = maxDue.toFixed(2);
    }

    function addPayment() {
        var amt = parseFloat(
            document.getElementById(
                'newPayAmt').value) || 0;
        var method = document.getElementById(
            'newPayMethod').value;
        var note = document.getElementById(
            'newPayNote').value;

        if (amt <= 0 || amt > maxDue) {
            toastr.error(
                'Invalid amount! Max: ৳'
                + maxDue.toFixed(2));
            return;
        }

        showSpinner('Adding payment...');

        $.ajax({
            url:  '@Url.Action("AddPayment","Sale")',
            type: 'POST',
            data: {
                invoiceId:     invId,
                paymentAmount: amt,
                paymentMethod: method,
                note:          note,
                __RequestVerificationToken:
                    $('input[name="__RequestVerificationToken"]')
                    .first().val()
            },
            success: function (res) {
                hideSpinner();
                if (res.success) {
                    toastr.success(res.message);
                    setTimeout(function () {
                        location.reload();
                    }, 1000);
                } else {
                    toastr.error(res.message);
                }
            },
            error: function () {
                hideSpinner();
                toastr.error('Something went wrong!');
            }
        });
    }
    </script>
    @Html.AntiForgeryToken()
}