@model PharmacyProMS.ViewModels.MedicineBatchListViewModel
@{
    ViewBag.Title = "Medicine Batches";
    var today = DateTime.Today;
    var day90 = today.AddDays(90);
}

<div class="page-header">
    <div>
        <h4>
            <i class="fas fa-boxes me-2"
               style="color:#1a8a5a"></i>
            Medicine Batches
        </h4>
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item">
                <a href="@Url.Action("Index","Dashboard")">
                    Home
                </a>
            </li>
            <li class="breadcrumb-item active">Batches</li>
        </ol>
    </div>
    <a href="@Url.Action("Create")"
       class="btn btn-primary">
        <i class="fas fa-plus me-1"></i> Add Batch
    </a>
</div>

@* Stats *@
<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card text-center py-3">
            <div style="font-size:26px;font-weight:700;
                        color:#1a8a5a">
                @Model.TotalCount
            </div>
            <div class="text-muted small">Total Batches</div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card text-center py-3">
            <div style="font-size:26px;font-weight:700;
                        color:#ffc107">
                @Model.Batches.Count(b =>
                    b.ExpiryDate >= today &&
                    b.ExpiryDate <= day90)
            </div>
            <div class="text-muted small">
                Expiring Soon
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card text-center py-3">
            <div style="font-size:26px;font-weight:700;
                        color:#dc3545">
                @Model.Batches.Count(b =>
                    b.ExpiryDate < today)
            </div>
            <div class="text-muted small">Expired</div>
        </div>
    </div>
</div>

@* Filter *@
<div class="card mb-3">
    <div class="card-body py-3">
        @using (Html.BeginForm("Index", "MedicineBatch",
            FormMethod.Get,
            new { @class = "row g-2 align-items-end" }))
        {
            <div class="col-md-3">
                <label class="form-label fw-semibold small">
                    Search
                </label>
                <div class="input-group">
                    <span class="input-group-text bg-white">
                        <i class="fas fa-search text-muted"></i>
                    </span>
                    <input type="text" name="searchTerm"
                           value="@Model.SearchTerm"
                           class="form-control"
                           placeholder="Batch no, medicine..." />
                </div>
            </div>
            <div class="col-md-3">
                <label class="form-label fw-semibold small">
                    Medicine
                </label>
                @Html.DropDownList("filterMedicine",
                    new SelectList(Model.Medicines,
                        "MedicineId", "MedicineName",
                        Model.FilterMedicine),
                    "All Medicines",
                    new { @class = "form-select" })
            </div>
            <div class="col-md-2">
                <label class="form-label fw-semibold small">
                    Status
                </label>
                <select name="filterStatus"
                        class="form-select">
                    <option value=""
                            @(Model.FilterStatus == "" ? "selected" : "")>
                        All
                    </option>
                    <option value="ok"
                            @(Model.FilterStatus == "ok" ? "selected" : "")>
                        ✅ Good
                    </option>
                    <option value="expiring"
                            @(Model.FilterStatus == "expiring" ? "selected" : "")>
                        ⚠️ Expiring
                    </option>
                    <option value="expired"
                            @(Model.FilterStatus == "expired" ? "selected" : "")>
                        ❌ Expired
                    </option>
                </select>
            </div>
            <div class="col-md-4 d-flex gap-2">
                <button type="submit"
                        class="btn btn-primary w-100">
                    <i class="fas fa-filter me-1"></i>
                    Filter
                </button>
                <a href="@Url.Action("Index")"
                   class="btn btn-outline-secondary">
                    <i class="fas fa-redo"></i>
                </a>
            </div>
        }
    </div>
</div>

@* Table *@
<div class="card">
    <div class="card-header d-flex
                justify-content-between">
        <span>
            <i class="fas fa-list me-2"></i>
            Batch List
            <span class="badge ms-2"
                  style="background:#e8f5ee;color:#1a8a5a">
                @Model.TotalCount Records
            </span>
        </span>
        <small class="text-muted">
            Page @Model.CurrentPage of @Model.TotalPages
        </small>
    </div>

    <div class="card-body p-0">
        <div class="table-responsive">
            <table id="batchTable"
                   class="table table-hover w-100">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Medicine</th>
                        <th>Batch No</th>
                        <th>Purchase Price</th>
                        <th>Mfg Date</th>
                        <th>Expiry Date</th>
                        <th>Qty</th>
                        <th>Supplier</th>
                        <th>Status</th>
                        <th style="width:100px">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Batches.Any())
                    {
                        <tr>
                            <td colspan="10"
                                class="text-center py-5">
                                <i class="fas fa-inbox"
                                   style="font-size:40px;
                                          color:#ddd"></i>
                                <p class="text-muted mt-2">
                                    No batches found
                                </p>
                            </td>
                        </tr>
                    }
                    @{
                        int sl = (Model.CurrentPage - 1)
                                 * Model.PageSize + 1;
                    }
                    @foreach (var b in Model.Batches)
                    {
                        bool isExpired = b.ExpiryDate < today;
                        bool isExpiring = !isExpired &&
                            b.ExpiryDate <= day90;
                        int daysLeft =
                            (b.ExpiryDate - today).Days;

                        string rowClass = isExpired
                            ? "table-danger"
                            : isExpiring
                                ? "table-warning" : "";
                        string badgeClass = isExpired
                            ? "bg-danger"
                            : isExpiring
                                ? "bg-warning" : "bg-success";
                        string statusText = isExpired
                            ? "Expired"
                            : isExpiring
                                ? daysLeft + "d left" : "Good";

                        <tr id="batch-row-@b.BatchId"
                            class="@rowClass">
                            <td class="text-muted">@sl</td>
                            <td class="fw-semibold">
                                @(b.Medicine != null
                                    ? b.Medicine.MedicineName
                                    : "—")
                            </td>
                            <td>
                                <span class="badge bg-secondary">
                                    @b.BatchNumber
                                </span>
                            </td>
                            <td>
                                ৳ @String.Format("{0:N2}",
                              b.PurchasePrice)
                            </td>
                            <td class="text-muted small">
                                @(b.ManufactureDate.HasValue
                                    ? b.ManufactureDate.Value
                                        .ToString("dd MMM yyyy",
                                        System.Globalization
                                        .CultureInfo
                                        .InvariantCulture)
                                    : "—")
                            </td>
                            <td>
                                <span class="@(isExpired
                                    ? "text-danger fw-bold"
                                    : isExpiring
                                        ? "text-warning fw-bold"
                                        : "")">
                                    @b.ExpiryDate.ToString(
                                        "dd MMM yyyy",
                                        System.Globalization
                                        .CultureInfo
                                        .InvariantCulture)
                                </span>
                            </td>
                            <td>
                                <span class="badge @(b.Quantity==0
                                    ? "bg-danger"
                                    : "bg-success")">
                                    @b.Quantity
                                </span>
                            </td>
                            <td class="text-muted small">
                                @(b.Supplier != null
                                    ? b.Supplier.SupplierName
                                    : "—")
                            </td>
                            <td>
                                <span class="badge @badgeClass">
                                    @statusText
                                </span>
                            </td>
                            <td>
                                <div class="d-flex gap-1">
                                    <a href="@Url.Action(
                                        "Edit",
                                        new{id=b.BatchId})"
                                       class="btn btn-sm
                                              btn-outline-warning">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    @if (User.IsInRole("Admin"))
                                    {
                                        <button class="btn btn-sm
                                                   btn-outline-danger"
                                                onclick="confirmDelete(@b.BatchId,
                                                     '@b.BatchNumber', 'MedicineBatch')">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    }
                                </div>
                            </td>
                        </tr>
                        sl++;
                    }
                </tbody>
            </table>
        </div>
    </div>

    @* Pagination *@
    @if (Model.TotalPages > 1)
    {
        <div class="card-footer d-flex
                    justify-content-between">
            <small class="text-muted">
                Showing
                @((Model.CurrentPage-1)*Model.PageSize+1)
                to @(Math.Min(
                    Model.CurrentPage * Model.PageSize,
                    Model.TotalCount))
                of @Model.TotalCount
            </small>
            <ul class="pagination pagination-sm mb-0">
                <li class="page-item
                    @(Model.CurrentPage==1?"disabled":"")">
                    <a class="page-link"
                       href="@Url.Action("Index", new {
                           searchTerm     = Model.SearchTerm,
                           filterMedicine = Model.FilterMedicine,
                           filterStatus   = Model.FilterStatus,
                           page = Model.CurrentPage - 1 })">
                        <i class="fas fa-chevron-left"></i>
                    </a>
                </li>
                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item
                        @(i==Model.CurrentPage?"active":"")">
                        <a class="page-link"
                           href="@Url.Action("Index", new {
                               searchTerm     = Model.SearchTerm,
                               filterMedicine = Model.FilterMedicine,
                               filterStatus   = Model.FilterStatus,
                               page           = i })">@i</a>
                        </li>
                    }
                <li class="page-item
                    @(Model.CurrentPage==Model.TotalPages
                        ?"disabled":"")">
                    <a class="page-link"
                       href="@Url.Action("Index", new {
                           searchTerm     = Model.SearchTerm,
                           filterMedicine = Model.FilterMedicine,
                           filterStatus   = Model.FilterStatus,
                           page = Model.CurrentPage + 1 })">
                        <i class="fas fa-chevron-right"></i>
                    </a>
                </li>
            </ul>
        </div>
    }
</div>

@section Scripts {
    <script>
    @*function deleteBatch(id, num) {
        if (!confirm('Delete Batch "' + num + '"?\n' +
            'Stock will be reversed!')) return;
        $.ajax({
            url: '@Url.Action("Delete","MedicineBatch")',
            type: 'POST',
            data: {
                id: id,
                __RequestVerificationToken:
                    $('input[name="__RequestVerificationToken"]')
                    .val()
            },
            success: function (res) {
                if (res.success) {
                    $('#batch-row-' + id).fadeOut(400,
                        function () { $(this).remove(); });
                    toastr.success(res.message);
                } else {
                    toastr.error(res.message);
                }
            }
        });
    }*@
  
    $('#batchTable').DataTable({
        responsive: true,
        pageLength: 10,
        lengthMenu: [[10, 25, 50, -1],
                     [10, 25, 50, "All"]],
        order:      [[5, 'asc']],
        columnDefs: [
            { orderable: false, targets: [8, 9] }
        ],
        language: {
            search:   "🔍 Search:",
            info:     "Showing _START_ to _END_ of _TOTAL_",
            paginate: { previous: "‹", next: "›" }
        }
    });
    </script>
    @Html.AntiForgeryToken()
}