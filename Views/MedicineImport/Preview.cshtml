@model PharmacyProMS.ViewModels.MedicineImportPreviewViewModel
@{
    ViewBag.Title = "Preview Import Data";
}

<div class="page-header">
    <div>
        <h4>
            <i class="fas fa-eye me-2"
               style="color:#1a8a5a"></i>
            Preview Import Data
        </h4>
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item">
                <a href="@Url.Action("Index","Dashboard")">
                    Home
                </a>
            </li>
            <li class="breadcrumb-item">
                <a href="@Url.Action("Index")">Import</a>
            </li>
            <li class="breadcrumb-item active">Preview</li>
        </ol>
    </div>
    <a href="@Url.Action("Index")"
       class="btn btn-outline-secondary">
        <i class="fas fa-arrow-left me-1"></i>
        Back to Upload
    </a>
</div>

@* Summary Cards *@
<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card text-center p-3">
            <div style="font-size:32px;font-weight:700;
                        color:#2196f3">
                @Model.TotalRows
            </div>
            <div class="text-muted small">
                Total Rows in Excel
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card text-center p-3"
             style="border-top:3px solid #4caf50">
            <div style="font-size:32px;font-weight:700;
                        color:#4caf50">
                @Model.ValidCount
            </div>
            <div class="text-muted small">
                ✅ Ready to Import
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card text-center p-3"
             style="border-top:3px solid #dc3545">
            <div style="font-size:32px;font-weight:700;
                        color:#dc3545">
                @Model.InvalidCount
            </div>
            <div class="text-muted small">
                ❌ Has Errors (will be skipped)
            </div>
        </div>
    </div>
</div>

@* Invalid Rows Warning *@
@if (Model.InvalidCount > 0)
{
    <div class="alert alert-warning mb-3">
        <i class="fas fa-exclamation-triangle me-2"></i>
        <strong>@Model.InvalidCount rows</strong>
        have errors and will be skipped.
        Fix them in Excel and re-upload if needed.
    </div>

    <div class="card mb-4"
         style="border-left:4px solid #dc3545">
        <div class="card-header text-danger">
            <i class="fas fa-times-circle me-2"></i>
            Rows with Errors
        </div>
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>Row</th>
                        <th>Medicine Name</th>
                        <th>Error</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in Model.InvalidRows)
                    {
                        <tr class="table-danger">
                            <td>@row.RowNumber</td>
                            <td>@row.MedicineName</td>
                            <td>
                                <span class="text-danger small">
                                    @row.ErrorMessage
                                </span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@* Valid Rows Preview *@
@if (Model.ValidCount > 0)
{
    <div class="card">
        <div class="card-header d-flex
                    justify-content-between">
            <span>
                <i class="fas fa-check-circle me-2
                           text-success"></i>
                Ready to Import
                <span class="badge ms-2"
                      style="background:#e8f5ee;
                             color:#1a8a5a">
                    @Model.ValidCount Medicines
                </span>
            </span>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive"
                 style="max-height:400px;
                        overflow-y:auto">
                <table class="table table-hover mb-0">
                    <thead style="position:sticky;top:0">
                        <tr>
                            <th>#</th>
                            <th>Medicine Name</th>
                            <th>Generic</th>
                            <th>Company</th>
                            <th>Category</th>
                            <th>Unit</th>
                            <th>Price</th>
                            <th>Re-Order</th>
                            <th>Barcode</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{ int i = 1; }
                        @foreach (var row in Model.ValidRows)
                        {
                            <tr>
                                <td class="text-muted">
                                    @i
                                </td>
                                <td class="fw-semibold">
                                    @row.MedicineName
                                </td>
                                <td class="text-muted small">
                                    @row.GenericName
                                </td>
                                <td>
                                    <span class="badge"
                                          style="background:#e8f5ee;
                                                 color:#1a8a5a">
                                        @row.CompanyName
                                    </span>
                                </td>
                                <td>
                                    <small>
                                        @row.CategoryName
                                    </small>
                                </td>
                                <td>
                                    <small class="text-muted">
                                        @row.UnitType
                                    </small>
                                </td>
                                <td class="fw-semibold">
                                    ৳ @String.Format("{0:N2}",
                                      row.SalePrice)
                                </td>
                                <td>@row.ReOrderLevel</td>
                                <td class="text-muted small">
                                    @(string.IsNullOrEmpty(
                                        row.Barcode)
                                        ? "—" : row.Barcode)
                                </td>
                            </tr>
                            i++;
                        }
                    </tbody>
                </table>
            </div>
        </div>

        @* Confirm Button *@
        <div class="card-footer">
            @using (Html.BeginForm("ConfirmImport",
                "MedicineImport", FormMethod.Post))
            {
                @Html.AntiForgeryToken()
                <input type="hidden"
                       name="importDataJson"
                       value="@Model.ImportDataJson" />

                <div class="d-flex
                            justify-content-between
                            align-items-center">
                    <div class="text-muted small">
                        <i class="fas fa-info-circle
                                   me-1"></i>
                        @Model.ValidCount medicines will
                        be imported.
                        Duplicate medicines will be
                        automatically skipped.
                    </div>
                    <div class="d-flex gap-2">
                        <a href="@Url.Action("Index")"
                           class="btn btn-outline-secondary">
                            <i class="fas fa-times me-1"></i>
                            Cancel
                        </a>
                        <button type="submit"
                                class="btn btn-success px-4"
                                onclick="return confirm(
                                    'Import '
                                    + '@Model.ValidCount'
                                    + ' medicines?')">
                            <i class="fas fa-check me-2"></i>
                            Confirm Import
                            (@Model.ValidCount medicines)
                        </button>
                    </div>
                </div>
            }
        </div>
    </div>
}
else
{
    <div class="card">
        <div class="card-body text-center py-5">
            <i class="fas fa-exclamation-circle"
               style="font-size:50px;color:#dc3545"></i>
            <h5 class="mt-3 text-danger">
                No valid data to import!
            </h5>
            <p class="text-muted">
                All rows have errors.
                Please fix them and try again.
            </p>
            <a href="@Url.Action("Index")"
               class="btn btn-primary mt-2">
                <i class="fas fa-redo me-2"></i>
                Try Again
            </a>
        </div>
    </div>
}