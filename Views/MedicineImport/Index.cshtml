@{
    ViewBag.Title = "Import Medicines";
}

<div class="page-header">
    <div>
        <h4>
            <i class="fas fa-file-excel me-2"
               style="color:#1a8a5a"></i>
            Import Medicines from Excel
        </h4>
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item">
                <a href="@Url.Action("Index","Dashboard")">
                    Home
                </a>
            </li>
            <li class="breadcrumb-item">
                <a href="@Url.Action("Index","Medicine")">
                    Medicines
                </a>
            </li>
            <li class="breadcrumb-item active">
                Import
            </li>
        </ol>
    </div>
    <a href="@Url.Action("Index","Medicine")"
       class="btn btn-outline-secondary">
        <i class="fas fa-arrow-left me-1"></i> Back
    </a>
</div>

@* How it works *@
<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card text-center p-4 h-100">
            <div style="width:60px;height:60px;
                        background:#e8f5ee;
                        border-radius:50%;
                        display:flex;
                        align-items:center;
                        justify-content:center;
                        margin:0 auto 15px">
                <span style="font-size:22px;
                             font-weight:900;
                             color:#1a8a5a">1</span>
            </div>
            <h6 class="fw-bold">Download Template</h6>
            <p class="text-muted small mb-0">
                Excel template download করো
            </p>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-center p-4 h-100">
            <div style="width:60px;height:60px;
                        background:#e3f2fd;
                        border-radius:50%;
                        display:flex;
                        align-items:center;
                        justify-content:center;
                        margin:0 auto 15px">
                <span style="font-size:22px;
                             font-weight:900;
                             color:#2196f3">2</span>
            </div>
            <h6 class="fw-bold">Fill Medicine Data</h6>
            <p class="text-muted small mb-0">
                Excel এ medicine info দাও
            </p>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-center p-4 h-100">
            <div style="width:60px;height:60px;
                        background:#fff3e0;
                        border-radius:50%;
                        display:flex;
                        align-items:center;
                        justify-content:center;
                        margin:0 auto 15px">
                <span style="font-size:22px;
                             font-weight:900;
                             color:#ff9800">3</span>
            </div>
            <h6 class="fw-bold">Upload & Preview</h6>
            <p class="text-muted small mb-0">
                File upload করো — preview দেখো
            </p>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-center p-4 h-100">
            <div style="width:60px;height:60px;
                        background:#e8f5e9;
                        border-radius:50%;
                        display:flex;
                        align-items:center;
                        justify-content:center;
                        margin:0 auto 15px">
                <span style="font-size:22px;
                             font-weight:900;
                             color:#4caf50">4</span>
            </div>
            <h6 class="fw-bold">Import Done!</h6>
            <p class="text-muted small mb-0">
                Confirm করো — সব import হবে
            </p>
        </div>
    </div>
</div>

<div class="row g-3">

    @* Download Template *@
    <div class="col-md-5">
        <div class="card h-100">
            <div class="card-header">
                <i class="fas fa-download me-2"></i>
                Step 1 — Download Template
            </div>
            <div class="card-body p-4 text-center">
                <div style="width:80px;height:80px;
                            background:#e8f5ee;
                            border-radius:16px;
                            display:flex;
                            align-items:center;
                            justify-content:center;
                            margin:0 auto 20px">
                    <i class="fas fa-file-excel"
                       style="font-size:36px;
                              color:#1a8a5a"></i>
                </div>
                <h6 class="fw-bold mb-2">
                    MedicineImportTemplate.xlsx
                </h6>
                <p class="text-muted small mb-4">
                    এই template download করো।<br />
                    এতে sample data ও instructions আছে।<br />
                    নিজের medicine data fill করো।
                </p>
                <a href="@Url.Action("DownloadTemplate")"
                   class="btn btn-success px-4">
                    <i class="fas fa-download me-2"></i>
                    Download Template
                </a>
            </div>
        </div>
    </div>

    @* Upload File *@
    <div class="col-md-7">
        <div class="card h-100">
            <div class="card-header">
                <i class="fas fa-upload me-2"></i>
                Step 2 — Upload Excel File
            </div>
            <div class="card-body p-4">

                @if (TempData["Error"] != null)
                {
                    <div class="alert alert-danger mb-3">
                        <i class="fas fa-exclamation-circle
                                   me-2"></i>
                        @TempData["Error"]
                    </div>
                }

                @using (Html.BeginForm("Preview",
                    "MedicineImport",
                    FormMethod.Post,
                    new
                    {
                        enctype = "multipart/form-data",
                        id = "uploadForm"
                    }))
                {
                    @Html.AntiForgeryToken()

                    @* File Drop Zone *@
                    <div id="dropZone"
                         onclick="document.getElementById(
                             'excelFile').click()"
                         style="border:2px dashed #1a8a5a;
                                border-radius:12px;
                                padding:40px;
                                text-align:center;
                                cursor:pointer;
                                transition:all 0.3s;
                                background:#fafafa;
                                margin-bottom:20px">
                        <i class="fas fa-cloud-upload-alt"
                           style="font-size:40px;
                                  color:#1a8a5a;
                                  margin-bottom:10px;
                                  display:block"></i>
                        <p class="fw-semibold mb-1">
                            Click to select Excel file
                        </p>
                        <p class="text-muted small mb-0">
                            or drag & drop here
                        </p>
                        <p class="text-muted small">
                            Supported: .xlsx, .xls
                        </p>
                    </div>

                    <input type="file"
                           name="excelFile"
                           id="excelFile"
                           accept=".xlsx,.xls"
                           style="display:none"
                           onchange="onFileSelect(this)" />

                    @* Selected File Info *@
                    <div id="fileInfo"
                         class="alert"
                         style="background:#e8f5ee;
                                border-color:#1a8a5a;
                                display:none">
                        <i class="fas fa-file-excel me-2"
                           style="color:#1a8a5a"></i>
                        <span id="fileName"
                              class="fw-semibold"></span>
                        <span id="fileSize"
                              class="text-muted ms-2 small">
                        </span>
                        <button type="button"
                                class="btn-close float-end"
                                onclick="clearFile()">
                        </button>
                    </div>

                    <button type="submit"
                            id="uploadBtn"
                            class="btn btn-primary w-100"
                            disabled>
                        <i class="fas fa-search me-2"></i>
                        Preview Data
                    </button>
                }

                @* Tips *@
                <div class="mt-3 p-3 rounded"
                     style="background:#f8f9fa">
                    <h6 class="fw-bold small mb-2">
                        <i class="fas fa-lightbulb me-1
                                   text-warning"></i>
                        Tips:
                    </h6>
                    <ul class="small text-muted mb-0 ps-3">
                        <li>Header row change করবে না</li>
                        <li>
                            Company না থাকলে
                            automatically তৈরি হবে
                        </li>
                        <li>
                            Category না থাকলে
                            automatically তৈরি হবে
                        </li>
                        <li>
                            Duplicate medicine
                            automatically skip হবে
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
    var dropZone = document.getElementById('dropZone');
    var fileInput = document.getElementById('excelFile');

    // Drag & Drop
    dropZone.addEventListener('dragover', function (e) {
        e.preventDefault();
        this.style.background = '#e8f5ee';
        this.style.borderColor = '#0d5c3a';
    });

    dropZone.addEventListener('dragleave', function () {
        this.style.background = '#fafafa';
        this.style.borderColor = '#1a8a5a';
    });

    dropZone.addEventListener('drop', function (e) {
        e.preventDefault();
        this.style.background = '#fafafa';
        this.style.borderColor = '#1a8a5a';

        var files = e.dataTransfer.files;
        if (files.length > 0) {
            fileInput.files = files;
            onFileSelect(fileInput);
        }
    });

    function onFileSelect(input) {
        if (!input.files || !input.files[0]) return;

        var file = input.files[0];
        var ext  = file.name.split('.').pop().toLowerCase();

        if (ext !== 'xlsx' && ext !== 'xls') {
            alert('Only Excel files allowed!');
            clearFile();
            return;
        }

        var size = (file.size / 1024).toFixed(1) + ' KB';
        if (file.size > 1024 * 1024)
            size = (file.size / 1024 / 1024)
                .toFixed(1) + ' MB';

        document.getElementById('fileName').textContent
            = file.name;
        document.getElementById('fileSize').textContent
            = '(' + size + ')';
        document.getElementById('fileInfo').style.display
            = 'block';
        document.getElementById('uploadBtn').disabled
            = false;
        document.getElementById('dropZone').style.background
            = '#e8f5ee';
    }

    function clearFile() {
        fileInput.value = '';
        document.getElementById('fileInfo').style.display
            = 'none';
        document.getElementById('uploadBtn').disabled
            = true;
        document.getElementById('dropZone').style.background
            = '#fafafa';
    }
    </script>
}