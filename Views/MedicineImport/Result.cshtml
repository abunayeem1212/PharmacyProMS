@{
    ViewBag.Title = "Import Result";
    int success = (int)(ViewBag.SuccessCount ?? 0);
    int skip = (int)(ViewBag.SkipCount ?? 0);
    int errors = (int)(ViewBag.ErrorCount ?? 0);
}

<div class="page-header">
    <div>
        <h4>
            <i class="fas fa-check-circle me-2"
               style="color:#1a8a5a"></i>
            Import Complete
        </h4>
    </div>
</div>

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card text-center p-5">

            @* Success Icon *@
            <div style="width:100px;height:100px;
                        background:#e8f5ee;
                        border-radius:50%;
                        display:flex;
                        align-items:center;
                        justify-content:center;
                        margin:0 auto 20px">
                <i class="fas fa-check-circle"
                   style="font-size:50px;
                          color:#1a8a5a"></i>
            </div>

            <h3 class="fw-bold mb-4">
                Import Complete!
            </h3>

            @* Result Summary *@
            <div class="row g-3 mb-4">
                <div class="col-4">
                    <div class="p-3 rounded"
                         style="background:#e8f5ee">
                        <div style="font-size:28px;
                                    font-weight:700;
                                    color:#1a8a5a">
                            @success
                        </div>
                        <div class="text-muted small">
                            Imported
                        </div>
                    </div>
                </div>
                <div class="col-4">
                    <div class="p-3 rounded"
                         style="background:#fff3e0">
                        <div style="font-size:28px;
                                    font-weight:700;
                                    color:#ff9800">
                            @skip
                        </div>
                        <div class="text-muted small">
                            Skipped
                            (Duplicate)
                        </div>
                    </div>
                </div>
                <div class="col-4">
                    <div class="p-3 rounded"
                         style="background:#fce4ec">
                        <div style="font-size:28px;
                                    font-weight:700;
                                    color:#e91e63">
                            @errors
                        </div>
                        <div class="text-muted small">
                            Errors
                        </div>
                    </div>
                </div>
            </div>

            @if (skip > 0)
            {
                <div class="alert alert-warning
                            text-start mb-3">
                    <i class="fas fa-info-circle me-2"></i>
                    <strong>@skip medicines</strong>
                    were skipped because they already
                    exist in the database.
                </div>
            }

            <div class="d-flex gap-2
                        justify-content-center">
                <a href="@Url.Action("Index","Medicine")"
                   class="btn btn-primary px-4">
                    <i class="fas fa-pills me-2"></i>
                    View Medicines
                </a>
                <a href="@Url.Action("Index")"
                   class="btn btn-outline-secondary px-4">
                    <i class="fas fa-upload me-2"></i>
                    Import More
                </a>
            </div>
        </div>
    </div>
</div>