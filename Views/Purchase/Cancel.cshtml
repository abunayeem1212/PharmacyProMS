@model PharmacyProMS.Models.PurchaseInvoice
@{
    ViewBag.Title = "Cancel Purchase Invoice";
}

<div class="page-header">
    <div>
        <h4>
            <i class="fas fa-ban me-2 text-danger"></i>
            Cancel Purchase Invoice
        </h4>
    </div>
    <a href="@Url.Action("Details",
        new{id=Model.PurchaseId})"
       class="btn btn-outline-secondary">
        <i class="fas fa-arrow-left me-1"></i> Back
    </a>
</div>

<div class="row justify-content-center">
    <div class="col-md-6">

        <div class="card mb-3"
             style="border-left:4px solid #dc3545">
            <div class="card-body">
                <div class="row text-center">
                    <div class="col-4">
                        <div class="text-muted small">
                            Invoice No
                        </div>
                        <div class="fw-bold text-danger">
                            @Model.InvoiceNumber
                        </div>
                    </div>
                    <div class="col-4">
                        <div class="text-muted small">
                            Supplier
                        </div>
                        <div class="fw-bold">
                            @(Model.Supplier != null
                                ? Model.Supplier.SupplierName
                                : "—")
                        </div>
                    </div>
                    <div class="col-4">
                        <div class="text-muted small">
                            Amount
                        </div>
                        <div class="fw-bold">
                            ৳ @String.Format("{0:N2}",
                              Model.NetAmount)
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="alert alert-danger">
            <i class="fas fa-exclamation-triangle me-2"></i>
            <strong>Warning!</strong> This cannot be undone.
            <ul class="small mb-0 mt-2">
                <li>Stock will be reversed</li>
                <li>Batch quantities will be zeroed</li>
                <li>Invoice marked as Cancelled</li>
            </ul>
        </div>

        <div class="card">
            <div class="card-header fw-bold text-danger">
                <i class="fas fa-ban me-2"></i>
                Confirm Cancellation
            </div>
            <div class="card-body p-4">
                @using (Html.BeginForm("Cancel", "Purchase",
                    new { id = Model.PurchaseId },
                    FormMethod.Post))
                {
                    @Html.AntiForgeryToken()
                    <div class="mb-4">
                        <label class="form-label fw-semibold">
                            Reason
                            <span class="text-danger">*</span>
                        </label>
                        <textarea name="cancelReason"
                                  class="form-control"
                                  rows="3"
                                  required
                                  placeholder="Enter cancellation reason...">
                        </textarea>
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit"
                                class="btn btn-danger px-4"
                                onclick="return confirm(
                                    'Confirm cancellation?')">
                            <i class="fas fa-ban me-2"></i>
                            Cancel Invoice
                        </button>
                        <a href="@Url.Action("Details",
                            new{id=Model.PurchaseId})"
                           class="btn btn-outline-secondary">
                            Go Back
                        </a>
                    </div>
                }
            </div>
        </div>
    </div>
</div>