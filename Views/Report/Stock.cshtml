@model IEnumerable<PharmacyProMS.Models.Medicine>
@{
    ViewBag.Title = "Stock Report";
    string filter = ViewBag.Filter ?? "all";
}

<div class="page-header d-print-none">
    <div>
        <h4>
            <i class="fas fa-warehouse me-2"
               style="color:#1a8a5a"></i>
            Stock Report
        </h4>
    </div>
    <button onclick="window.print()"
            class="btn btn-outline-primary">
        <i class="fas fa-print me-1"></i> Print
    </button>

    <div class="d-flex gap-2">
        <a href="@Url.Action("ExportSalesExcel",
        new { dateFrom = ViewBag.DateFrom,
              dateTo   = ViewBag.DateTo })"
           class="btn btn-success">
            <i class="fas fa-file-excel me-1"></i>
            Export Excel
        </a>
        <button onclick="window.print()"
                class="btn btn-outline-primary">
            <i class="fas fa-print me-1"></i> Print
        </button>
    </div>
</div>

@* Filter *@
<div class="card mb-3 d-print-none">
    <div class="card-body py-3">
        @using (Html.BeginForm("Stock", "Report",
            FormMethod.Get,
            new { @class = "row g-2 align-items-end" }))
        {
            <div class="col-md-3">
                <label class="form-label fw-semibold small">
                    Stock Status
                </label>
                <select name="filter" class="form-select">
                    <option value="all"
                            @(filter == "all" ? "selected" : "")>
                        All Medicines
                    </option>
                    <option value="ok"
                            @(filter == "ok" ? "selected" : "")>
                        ✅ In Stock
                    </option>
                    <option value="low"
                            @(filter == "low" ? "selected" : "")>
                        ⚠️ Low Stock
                    </option>
                    <option value="out"
                            @(filter == "out" ? "selected" : "")>
                        ❌ Out of Stock
                    </option>
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label fw-semibold small">
                    Company
                </label>
                <select name="companyId" class="form-select">
                    <option value="">All Companies</option>
                    @foreach (var c in
                        (IEnumerable<PharmacyProMS.Models.Company>)
                        ViewBag.Companies)
                    {
                        <option value="@c.CompanyId"
                                @(ViewBag.CompanyId != null && (int)ViewBag.CompanyId == c.CompanyId ? "selected" : "")>
                            @c.CompanyName
                        </option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <button type="submit"
                        class="btn btn-primary w-100 mt-3">
                    <i class="fas fa-filter me-1"></i>
                    Filter
                </button>
            </div>
        }
    </div>
</div>

@* Summary *@
<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card text-center p-3">
            <div style="font-size:22px;font-weight:700;
                        color:#1a8a5a">
                @Model.Count()
            </div>
            <div class="text-muted small">Total Items</div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card text-center p-3">
            <div style="font-size:20px;font-weight:700;
                        color:#2196f3">
                ৳ @String.Format("{0:N2}", (decimal)ViewBag.TotalStockValue)
            </div>
            <div class="text-muted small">
                Total Stock Value (Sale Price)
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card text-center p-3">
            <div style="font-size:22px;font-weight:700;
                        color:#dc3545">
                @Model.Count(m => m.CurrentStock == 0)
            </div>
            <div class="text-muted small">Out of Stock</div>
        </div>
    </div>
</div>

@* Table *@
<div class="card">
    <div class="card-header">
        <i class="fas fa-boxes me-2"></i>
        Stock Report
    </div>
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Medicine</th>
                    <th>Generic</th>
                    <th>Company</th>
                    <th>Category</th>
                    <th>Unit</th>
                    <th>Sale Price</th>
                    <th>Current Stock</th>
                    <th>Re-Order</th>
                    <th>Status</th>
                    <th>Value</th>
                </tr>
            </thead>
            <tbody>
                @{ int i = 1; }
                @foreach (var m in Model)
                {
                    string status = m.CurrentStock == 0
                        ? "Out" : m.CurrentStock <=
                            m.ReOrderLevel
                            ? "Low" : "OK";
                    string sc = status == "Out"
                        ? "bg-danger" : status == "Low"
                            ? "bg-warning" : "bg-success";

                    <tr>
                        <td>@i</td>
                        <td class="fw-semibold">
                            @m.MedicineName
                        </td>
                        <td class="text-muted small">
                            @m.GenericName
                        </td>
                        <td>
                            @(m.Company != null
                                ? m.Company.CompanyName : "—")
                        </td>
                        <td>
                            @(m.Category != null
                                ? m.Category.CategoryName : "—")
                        </td>
                        <td>@m.UnitType</td>
                        <td>
                            ৳ @m.SalePrice.ToString("N2")
                        </td>
                        <td>
                            <span class="badge @sc"
                                  style="font-size:13px">
                                @m.CurrentStock
                            </span>
                        </td>
                        <td>@m.ReOrderLevel</td>
                        <td>
                            <span class="badge @sc">
                                @status
                            </span>
                        </td>
                        <td class="fw-semibold">
                            ৳ @((m.CurrentStock * m.SalePrice)
                                .ToString("N2"))
                        </td>
                    </tr>
                    i++;
                }
            </tbody>
        </table>
    </div>
</div>

<style>
    @@media print {
        .sidebar, .topbar, .d-print-none {
            display: none !important;
        }

        .main-content {
            margin: 0 !important;
            padding: 0 !important;
        }
    }
</style>